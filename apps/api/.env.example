# Variables d'environnement de l'app api (apps/api). Voir la racine .env.example pour la liste
# complète (Postgres, Better Auth, MinIO, Redis). NE JAMAIS commiter de vrai secret (CLAUDE.md).

# --- Puppeteer / Chromium (export PDF, PROP-07) ---
# CHEMIN d'un binaire système, PAS un secret. En conteneur (node:20-slim), Chromium est installé via
# apt dans /usr/bin/chromium. PUPPETEER_SKIP_DOWNLOAD empêche le téléchargement du Chromium bundlé.
# En dev hôte, laisser vides : Puppeteer utilise le Chromium qu'il a téléchargé localement
# (`pnpm --filter @kessel/proposals exec puppeteer browsers install chrome`).
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- MinIO (stockage du PDF signé, DELIV-03) ---
# Consommé par le client `minio` (StorageService). En compose, ENDPOINT/PORT/SSL sont câblés par le
# service api ; ACCESS/SECRET/BUCKET viennent du .env (voir racine .env.example).
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kessel
MINIO_SECRET_KEY=changeme-minio
MINIO_BUCKET=kessel-signed

# --- Signature PAdES (e-sign, DELIV-03) ---
# SIGNING_P12_PATH = CHEMIN du certificat PKCS#12 (PAS un secret). SIGNING_P12_PASSPHRASE = passphrase
# (SECRET, jamais loggée). Générer le .p12 via openssl (voir racine .env.example) ; jamais commité.
SIGNING_P12_PATH=/run/secrets/kessel-signing.p12
SIGNING_P12_PASSPHRASE=changeme-p12-passphrase
