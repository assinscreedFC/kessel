// Schéma métier multi-tenant de Kessel (FOUND-01). Prisma confiné à packages/shared/db (FOUND-05).
//
// SOURCE D'IDENTITÉ ORG CANONIQUE = Better Auth (Plan 04). Le plugin organization de Better Auth
// POSSÈDE les tables organization / member / role et expose activeOrganizationId en session.
// Prisma NE redéfinit PAS d'organisation/adhésion concurrentes :
//   - PAS de table d'adhésion Prisma, PAS d'énumération de rôles ici (Better Auth en est propriétaire).
//   - Le model Organization MAPPE la table canonique Better Auth `organization` (@@map),
//     pour que Organization.id === organization.id Better Auth (un seul espace d'id).
//   - Les entités métier (OrgNote, futurs modèles) portent orgId : FK vers cet id canonique.
//     L'orgId injecté par forOrg(session.activeOrganizationId) (Plan 03) référence donc toujours
//     un org qui existe réellement — aucun id orphelin possible (mitigation T-1-10).

generator client {
  provider = "prisma-client-js"
}

generator kysely {
  provider = "prisma-kysely"
  output   = "../src"
  fileName = "types.ts"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 : l'URL de connexion vit dans prisma.config.ts (datasource.url = env("DATABASE_URL")),
  // plus dans le bloc datasource du schéma. Un seul datastore partagé avec Better Auth.
}

// Organization : MAPPÉE sur la table canonique de Better Auth (@@map("organization")).
// Better Auth (Plan 04) crée et POSSÈDE cette table. Prisma en est un MIROIR FIDÈLE : il déclare
// EXACTEMENT les colonnes du plugin organization Better Auth (id, name, slug unique, logo, metadata,
// createdAt) pour qu'un `prisma db push` ne dérive JAMAIS cette table (pas de DROP de colonne/contrainte
// appartenant à Better Auth). En CI/runtime l'ordre est : Better Auth migrate D'ABORD (crée la table),
// puis push Prisma métier (no-op sur organization, crée OrgNote + le FK). id == organization.id canonique.
model Organization {
  id        String    @id // == organization.id de Better Auth (id canonique)
  name      String
  slug      String    @unique // colonne canonique Better Auth (contrainte unique)
  logo      String? // colonne canonique Better Auth (nullable)
  metadata  String? // colonne canonique Better Auth (JSON sérialisé, nullable)
  createdAt DateTime  @default(now())
  notes     OrgNote[]

  @@map("organization")
}

// Modèle tenant-scoped d'exemple métier (sert le test d'isolation FOUND-01, Plan 03).
// orgId est un FK vers l'id CANONIQUE Better Auth (Organization.id = organization.id).
// Toute FUTURE entité métier porte orgId String + @@index([orgId]) + FK vers Organization.id (FOUND-01).
model OrgNote {
  id        String   @id @default(uuid())
  orgId     String // FK -> Organization.id == organization.id (Better Auth) ; ne peut JAMAIS pointer un org inexistant
  body      String
  meta      Json? // champ custom JSONB (cahier §9 — pas EAV) ; index GIN posé en migration brute v2, non bloquant Phase 1
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
