// Schéma métier multi-tenant de Kessel (FOUND-01). Prisma confiné à packages/shared/db (FOUND-05).
//
// SOURCE D'IDENTITÉ ORG CANONIQUE = Better Auth (Plan 04). Le plugin organization de Better Auth
// POSSÈDE les tables organization / member / role et expose activeOrganizationId en session.
// Prisma NE redéfinit PAS d'organisation/adhésion concurrentes :
//   - PAS de table d'adhésion Prisma, PAS d'énumération de rôles ici (Better Auth en est propriétaire).
//   - Le model Organization MAPPE la table canonique Better Auth `organization` (@@map),
//     pour que Organization.id === organization.id Better Auth (un seul espace d'id).
//   - Les entités métier (OrgNote, futurs modèles) portent orgId : FK vers cet id canonique.
//     L'orgId injecté par forOrg(session.activeOrganizationId) (Plan 03) référence donc toujours
//     un org qui existe réellement — aucun id orphelin possible (mitigation T-1-10).

generator client {
  provider = "prisma-client-js"
}

generator kysely {
  provider = "prisma-kysely"
  output   = "../src"
  fileName = "types.ts"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 : l'URL de connexion vit dans prisma.config.ts (datasource.url = env("DATABASE_URL")),
  // plus dans le bloc datasource du schéma. Un seul datastore partagé avec Better Auth.
}

// Organization : MAPPÉE sur la table canonique de Better Auth (@@map("organization")).
// Better Auth (Plan 04) crée et POSSÈDE cette table. Prisma en est un MIROIR FIDÈLE : il déclare
// EXACTEMENT les colonnes du plugin organization Better Auth (id, name, slug unique, logo, metadata,
// createdAt) pour qu'un `prisma db push` ne dérive JAMAIS cette table (pas de DROP de colonne/contrainte
// appartenant à Better Auth). En CI/runtime l'ordre est : Better Auth migrate D'ABORD (crée la table),
// puis push Prisma métier (no-op sur organization, crée OrgNote + le FK). id == organization.id canonique.
model Organization {
  id        String    @id // == organization.id de Better Auth (id canonique)
  name      String
  slug      String    @unique // colonne canonique Better Auth (contrainte unique)
  logo      String? // colonne canonique Better Auth (nullable)
  metadata  String? // colonne canonique Better Auth (JSON sérialisé, nullable)
  createdAt DateTime  @default(now())
  notes     OrgNote[]
  contacts  Contact[]
  deals     Deal[]
  proposals         Proposal[]
  proposalTemplates ProposalTemplate[]
  pricingItems      PricingItem[]

  @@map("organization")
}

// Modèle tenant-scoped d'exemple métier (sert le test d'isolation FOUND-01, Plan 03).
// orgId est un FK vers l'id CANONIQUE Better Auth (Organization.id = organization.id).
// Toute FUTURE entité métier porte orgId String + @@index([orgId]) + FK vers Organization.id (FOUND-01).
model OrgNote {
  id        String   @id @default(uuid())
  orgId     String // FK -> Organization.id == organization.id (Better Auth) ; ne peut JAMAIS pointer un org inexistant
  body      String
  meta      Json? // champ custom JSONB (cahier §9 — pas EAV) ; index GIN posé en migration brute v2, non bloquant Phase 1
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// === CRM minimal (Phase 2) ===
// DealStatus : enum STABLE à 4 valeurs, ordre fixe. NE PAS ajouter de valeur — les phases
// suivantes en dépendent (DELIV-04 -> WON à la signature Phase 5 ; AI-01 lit WON/LOST Phase 6).
enum DealStatus {
  LEAD
  PROPOSAL_SENT
  WON
  LOST
}

// Contact : entité métier tenant-scoped (CRM-01). orgId FK -> Organization.id canonique.
// organizationName est un texte libre (PAS une entité Organization séparée en v0).
// Ajouté à SCOPED_MODELS (tenant-client.ts) + test d'isolation cross-tenant obligatoire.
model Contact {
  id               String   @id @default(uuid())
  orgId            String // FK -> Organization.id == organization.id (Better Auth)
  name             String
  email            String
  organizationName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals            Deal[]

  @@index([orgId])
}

// Deal : opportunité rattachée à exactement un Contact (CRM-02). orgId FK -> Organization.id.
// Deal.contact en onDelete: Restrict (PAS Cascade) : supprimer un contact ayant des deals liés
// ÉCHOUE (surface l'erreur, pas de cascade silencieuse). amount Decimal nullable (devis chiffré
// viendra des propositions). Ajouté à SCOPED_MODELS + test d'isolation cross-tenant.
model Deal {
  id        String     @id @default(uuid())
  orgId     String
  contactId String
  title     String
  status    DealStatus @default(LEAD)
  amount    Decimal?   @db.Decimal(12, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Restrict)
  proposals Proposal[]

  @@index([orgId])
  @@index([contactId])
  @@index([orgId, status])
}

// === Propositions & tarifs (Phase 3) ===
// ProposalStatus : ordre FIXE DRAFT -> SENT -> SIGNED. DRAFT posé en Phase 3 ; la Phase 5
// (livraison & e-sign) introduit SENT (à l'envoi, génère le share token) et SIGNED (à la signature
// PAdES). NE PAS réordonner ni retirer de valeur — les transitions (send/sign) et DELIV-04
// (deal -> WON à la signature) en dépendent.
enum ProposalStatus {
  DRAFT
  SENT
  SIGNED
}

// ProposalEventType : tracking d'ouverture/consultation du lien public (DELIV-02). SENT (envoi),
// OPENED (premier chargement du lien), VIEWED (consultation effective). Ordre fixe.
enum ProposalEventType {
  SENT
  OPENED
  VIEWED
}

// Proposal : corps de proposition rédigé (PROP-01). orgId FK -> Organization.id canonique.
// dealId FK -> Deal (une proposition appartient à un deal). bodyJson = document ProseMirror/Tiptap
// stocké en JSONB — c'est la SOURCE DE VÉRITÉ du corps (le PDF en est un rendu, pas l'inverse).
// Ajouté à SCOPED_MODELS (tenant-client.ts) + test d'isolation cross-tenant obligatoire.
model Proposal {
  id        String         @id @default(uuid())
  orgId     String // FK -> Organization.id == organization.id (Better Auth)
  dealId    String
  title     String
  bodyJson  Json // JSONB — document ProseMirror/Tiptap (source de vérité du corps)
  status    ProposalStatus @default(DRAFT)
  // === Livraison & e-sign (Phase 5) ===
  // shareTokenHash : SHA-256 (hex) du share token public, JAMAIS le token brut (T-5-token). Nullable
  // jusqu'à l'envoi. @unique -> lookup public O(1) par hash (basePrisma.findUnique, pas forOrg).
  shareTokenHash String? @unique
  sentAt    DateTime? // horodatage de l'envoi (transition DRAFT -> SENT)
  signedAt  DateTime? // horodatage de la signature (transition SENT -> SIGNED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal      Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lines     QuoteLine[]
  events    ProposalEvent[]
  signatures Signature[]
  outcome   ProposalOutcome? // issue structurée 1-0/1 (AI-01, Phase 6) — relation inverse

  @@index([orgId])
  @@index([dealId])
}

// ProposalTemplate : modèle réutilisable pour démarrer une proposition (PROP-02). orgId scopé.
// "Démarrer depuis template" copie bodyJson dans une nouvelle Proposal (copie serveur, pas de FK).
// Ajouté à SCOPED_MODELS + test d'isolation cross-tenant.
model ProposalTemplate {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  bodyJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// PricingItem : grille de tarifs (catalogue de prestations, PROP-03). orgId scopé.
// unit est un texte libre nullable ("jour" | "heure" | "forfait"). À l'ajout d'une QuoteLine depuis
// la grille, name/unitPrice sont COPIÉS (snapshot) — modifier la grille ne change jamais un devis.
// Ajouté à SCOPED_MODELS + test d'isolation cross-tenant.
model PricingItem {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  unitPrice Decimal  @db.Decimal(12, 2)
  unit      String? // "jour" | "heure" | "forfait" — texte libre nullable
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// QuoteLine : ligne de devis chiffré rattachée à une Proposal (PROP-03). PAS de colonne orgId :
// scopée via son parent Proposal (lui-même orgId-scopé). Tout accès aux lignes passe TOUJOURS par
// une Proposal forOrg-scopée — QuoteLine n'est donc PAS dans SCOPED_MODELS (cf. tenant-client.ts).
// SNAPSHOT (non négociable) : description/unitPrice copiés de PricingItem à l'ajout. AUCUNE FK vers
// PricingItem — un devis envoyé/signé ne doit jamais muter parce que la grille a changé.
// Total ligne = quantity × unitPrice et total devis = somme : CALCULÉS (decimal.js), jamais stockés.
model QuoteLine {
  id          String  @id @default(uuid())
  proposalId  String
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  position    Int
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

// === Livraison & e-sign (Phase 5) ===
// ProposalEvent : tracking ouvert/vu du lien public (DELIV-02). PAS de colonne orgId — scopé VIA son
// parent Proposal (exactement le pattern QuoteLine), donc VOLONTAIREMENT ABSENT de SCOPED_MODELS
// (tenant-client.ts) : l'y ajouter injecterait un orgId inexistant et casserait les requêtes.
// L'accès dashboard passe TOUJOURS par une Proposal forOrg-scopée
// (proposal.findUnique({ include: { events } })) — jamais par un proposalEvent.findMany direct ;
// l'isolation cross-tenant est prouvée par l'inaccessibilité du parent (delivery-isolation.spec.ts).
// meta JSONB nullable (RGPD, T-5-privacy) : ip TRONQUÉE (ex. /24) + ua tronqué, ou null. Pas de PII
// excessive, pas de pixel tiers, pas de colonne PII dédiée.
model ProposalEvent {
  id         String            @id @default(uuid())
  proposalId String
  type       ProposalEventType
  occurredAt DateTime          @default(now())
  meta       Json? // RGPD : ip tronquée/ua tronqué/null — jamais de PII brute
  proposal   Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

// Signature : enregistrement de la signature en ligne (DELIV-03, piste d'audit). PAS de colonne orgId
// — scopé VIA son parent Proposal (pattern QuoteLine), donc ABSENT de SCOPED_MODELS. Artefact légal
// (équivalent Documenso) : signerName/signerEmail (consentement saisi par le client), signedAt,
// documentHash (SHA-256 du PDF signé), signedPdfKey (clé MinIO du PDF stocké), auditTrail JSONB
// (snapshot borné des events — whitelist, jamais de PII brute). Accès médié par la Proposal forOrg-scopée.
model Signature {
  id           String   @id @default(uuid())
  proposalId   String
  signerName   String
  signerEmail  String
  signedAt     DateTime @default(now())
  documentHash String // SHA-256 (hex) du PDF signé — vérifiabilité de l'artefact
  signedPdfKey String // clé de l'objet MinIO (PDF signé stocké)
  auditTrail   Json? // snapshot borné des events (whitelist) — jamais de PII brute
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

// === Boucle de données flywheel (Phase 6, AI-01) ===
// OutcomeKind : issue d'une proposition résolue. Ordre fixe — AI-02 lit WON pour le few-shot,
// LOST disponible comme contre-signal futur (CONTEXT : gagné prioritaire en v0).
enum OutcomeKind {
  WON
  LOST
}

// ProposalOutcome : issue structurée d'une proposition résolue (AI-01). PAS de colonne orgId —
// scopé VIA son parent Proposal (pattern QuoteLine/ProposalEvent/Signature), donc ABSENT de
// SCOPED_MODELS (tenant-client.ts). proposalId @unique = une issue par proposition (idempotence).
// context JSONB = SNAPSHOT figé à la résolution (RGPD : pas de PII client — features dérivées +
// segment non-identifiant ; aucun nom/email). AI-02 lit outcome WON via readResolvedOutcomes.
model ProposalOutcome {
  id         String      @id @default(uuid())
  proposalId String      @unique
  outcome    OutcomeKind
  decidedAt  DateTime    @default(now())
  reason     String? // pourquoi gagné/perdu — optionnel (surtout LOST)
  context    Json // snapshot JSONB figé (amount string, lineCount, deliverableCount, bodyTextLength)
  proposal   Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}
