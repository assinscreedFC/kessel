# Kessel — variables d'environnement (exemple). NE JAMAIS commiter de vrai secret (CLAUDE.md security).
# Copier en `.env` (non commité) et adapter avec des valeurs de dev locales.

# --- Postgres ---
# MÊME datastore pour Prisma (métier) et Better Auth (organization/member/role, Plan 04).
# Un seul espace d'id organisation : pas de divergence Prisma <-> Better Auth.
POSTGRES_USER=kessel
POSTGRES_PASSWORD=changeme-postgres
POSTGRES_DB=kessel
# DATABASE_URL pointe le service `postgres` du compose (hostname = nom du service).
DATABASE_URL="postgresql://kessel:changeme-postgres@postgres:5432/kessel?schema=public"

# --- Better Auth ---
# Clé de signature des sessions/cookies. JAMAIS hardcodée. Générer : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-a-32-byte-hex-secret
# URL publique de confiance (cookies/CSRF) — Caddy expose l'app sur http://localhost en local.
BETTER_AUTH_URL=http://localhost

# --- MinIO (stockage S3-compatible, fichiers/PDF futurs) ---
MINIO_ROOT_USER=kessel
MINIO_ROOT_PASSWORD=changeme-minio

# --- Redis ---
# Pas d'auth en local (réseau interne compose). En prod : activer requirepass.
REDIS_URL=redis://redis:6379
