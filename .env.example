# Kessel — variables d'environnement (exemple). NE JAMAIS commiter de vrai secret (CLAUDE.md security).
# Copier en `.env` (non commité) et adapter avec des valeurs de dev locales.

# --- Postgres ---
# MÊME datastore pour Prisma (métier) et Better Auth (organization/member/role, Plan 04).
# Un seul espace d'id organisation : pas de divergence Prisma <-> Better Auth.
POSTGRES_USER=kessel
POSTGRES_PASSWORD=changeme-postgres
POSTGRES_DB=kessel
# DATABASE_URL pointe le service `postgres` du compose (hostname = nom du service).
DATABASE_URL="postgresql://kessel:changeme-postgres@postgres:5432/kessel?schema=public"

# --- Better Auth ---
# Clé de signature des sessions/cookies. JAMAIS hardcodée. Générer : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-a-32-byte-hex-secret
# URL publique de confiance (cookies/CSRF) — Caddy expose l'app sur http://localhost en local.
BETTER_AUTH_URL=http://localhost

# --- Serveur API ---
# Port d'écoute de l'api NestJS (défaut 3000 si absent). Caddy proxie /api -> ce port.
PORT=3000
# Origine publique utilisée pour construire les liens client (lien de partage proposition).
# Fallback sur BETTER_AUTH_URL si absent.
APP_ORIGIN=http://localhost

# --- IA (moteur de propositions, AI-01/AI-02) ---
# Clé API Anthropic. SECRET, jamais loggée. Absente -> la génération IA renvoie 503 (dégradation
# gracieuse), le reste de l'app fonctionne. Obtenir : https://console.anthropic.com/
ANTHROPIC_API_KEY=changeme-anthropic-api-key
# Modèle de génération (optionnel). Défaut : claude-sonnet-4-6.
KESSEL_AI_MODEL=claude-sonnet-4-6

# --- MinIO (stockage S3-compatible : PDF signé, DELIV-03) ---
MINIO_ROOT_USER=kessel
MINIO_ROOT_PASSWORD=changeme-minio
# Identifiants consommés par le client `minio` de l'api. = ROOT_USER/PASSWORD en local, ou des clés
# d'accès dédiées (MinIO console -> Access Keys) en prod. Le service `api` du compose câble en plus
# MINIO_ENDPOINT=minio / MINIO_PORT=9000 / MINIO_USE_SSL=false (réseau interne compose).
MINIO_ACCESS_KEY=kessel
MINIO_SECRET_KEY=changeme-minio
MINIO_BUCKET=kessel-signed

# --- Signature PAdES (e-sign, DELIV-03) ---
# Certificat PKCS#12 self-signed pour signer les PDF (pattern Documenso). Générer (jamais commiter le .p12) :
#   openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 3650 -nodes -subj "/CN=Kessel Self-Host"
#   openssl pkcs12 -export -out kessel-signing.p12 -inkey key.pem -in cert.pem -passout pass:CHANGEME
# SIGNING_P12_PATH = CHEMIN du .p12 (PAS un secret). SIGNING_P12_PASSPHRASE = passphrase (SECRET, jamais loggée).
SIGNING_P12_PATH=/run/secrets/kessel-signing.p12
SIGNING_P12_PASSPHRASE=changeme-p12-passphrase

# --- Redis ---
# Pas d'auth en local (réseau interne compose). En prod : activer requirepass.
REDIS_URL=redis://redis:6379

# --- Stripe (Phase 3, PAY-01..05) ---
# Clé secrète Stripe. SECRET, jamais loggée. Requise au boot (env.validation.ts).
# Obtenir : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Secret de signature des webhooks. OPTIONNEL (runtime-guarded). Générer : stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Puppeteer / Chromium (export PDF, PROP-07) ---
# CHEMIN d'un binaire système, PAS un secret. En conteneur (node:20-slim), Chromium est installé via
# apt et vit dans /usr/bin/chromium. PUPPETEER_SKIP_DOWNLOAD empêche Puppeteer de télécharger son
# Chromium glibc bundlé (inutile : on utilise le Chromium système). En dev hôte, laisser vides :
# Puppeteer utilise alors le Chromium qu'il a téléchargé (`pnpm exec puppeteer browsers install`).
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Portail client (Phase 4) ---
# Secret de signature JWT portail, distinct de BETTER_AUTH_SECRET.
# Générer : openssl rand -base64 48
PORTAL_JWT_SECRET=change-me-portal-secret-min-32-characters-long
# URL publique de l'app portail (apps/portal). Dev : http://localhost:5174
PORTAL_APP_URL=http://localhost:5174
