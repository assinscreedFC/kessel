# pnpm : hoister la toolchain Vite au node_modules racine.
# Vite charge sa config via un fichier .mjs temporaire écrit à la RACINE du workspace
# (node_modules/.vite-temp/) qui importe `vite`/les plugins ; sous l'isolement strict de pnpm
# ces paquets ne sont pas résolvables depuis la racine -> "Cannot find package 'vite'".
# public-hoist-pattern les expose au node_modules racine sans casser les frontières Nx (eslint).
public-hoist-pattern[]=vite
public-hoist-pattern[]=@vitejs/*
public-hoist-pattern[]=@tailwindcss/*
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=esbuild
public-hoist-pattern[]=rollup

# Externals runtime du bundle api (dist/apps/api/main.js, ESM avec --packages=external).
# Ces paquets sont des deps des packages workspace (@kessel/auth, @kessel/db), donc non hoistes
# par defaut sous l'isolement strict pnpm -> non resolvables depuis dist/. On les expose au
# node_modules racine pour que `node dist/apps/api/main.js` (et migrate.js) les resolve.
public-hoist-pattern[]=better-auth
public-hoist-pattern[]=pg
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=@prisma/adapter-pg
public-hoist-pattern[]=kysely
